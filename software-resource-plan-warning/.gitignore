# 忽略文件列表

# 依赖目录
node_modules/
venv/
__pycache__/
*.pyc

# 编译输出
dist/
build/
*.o
*.so
*.exe

# 日志文件
*.log
logs/

# 环境变量文件
.env
.env.local
.env.*.local

# IDE 配置
.vscode/
.idea/
*.swp
*.swo
*~

# 操作系统文件
.DS_Store
Thumbs.db

# 测试覆盖率
coverage/
*.coverage
.coverage.*

# 临时文件
tmp/
temp/
*.tmp

# 数据库文件
*.db
*.sqlite
*.sqlite3

# 配置文件（包含敏感信息）
config/local.yaml
config/production.yaml

# 打包文件
*.zip
*.tar
*.tar.gz
