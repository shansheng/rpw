<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             typeLanguage="http://www.w3.org/2001/XMLSchema"
             expressionLanguage="http://www.w3.org/1999/XPath"
             targetNamespace="http://www.company.com/rpw">

    <process id="laborChangeApproval" name="劳动力计划变更审批流程" isExecutable="true">

        <startEvent id="startEvent" name="开始"/>

        <userTask id="deptManagerApproval" name="部门经理审批" flowable:assignee="${applicant}"/>

        <exclusiveGateway id="deptGateway" name="部门经理审批结果"/>

        <userTask id="directorApproval" name="总监审批" flowable:assignee="${applicant}"/>

        <exclusiveGateway id="finalGateway" name="总监审批结果"/>

        <endEvent id="approveEnd" name="审批通过"/>
        <endEvent id="rejectEnd" name="审批驳回"/>

        <sequenceFlow id="flow1" sourceRef="startEvent" targetRef="deptManagerApproval"/>
        <sequenceFlow id="flow2" sourceRef="deptManagerApproval" targetRef="deptGateway"/>

        <sequenceFlow id="flow3" sourceRef="deptGateway" targetRef="directorApproval">
            <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow4" sourceRef="deptGateway" targetRef="rejectEnd">
            <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow5" sourceRef="directorApproval" targetRef="finalGateway"/>

        <sequenceFlow id="flow6" sourceRef="finalGateway" targetRef="approveEnd">
            <conditionExpression xsi:type="tFormalExpression">${approved == true}</conditionExpression>
        </sequenceFlow>

        <sequenceFlow id="flow7" sourceRef="finalGateway" targetRef="rejectEnd">
            <conditionExpression xsi:type="tFormalExpression">${approved == false}</conditionExpression>
        </sequenceFlow>

    </process>

    <bpmndi:BPMNDiagram id="BPMNDiagram_laborChange">
        <bpmndi:BPMNPlane id="BPMNPlane_laborChange" bpmnElement="laborChangeApproval">

            <!-- 开始事件 -->
            <bpmndi:BPMNShape id="shape_startEvent" bpmnElement="startEvent">
                <dc:Bounds x="180" y="230" width="36" height="36"/>
            </bpmndi:BPMNShape>

            <!-- 部门经理审批 -->
            <bpmndi:BPMNShape id="shape_deptManagerApproval" bpmnElement="deptManagerApproval">
                <dc:Bounds x="280" y="208" width="100" height="80"/>
            </bpmndi:BPMNShape>

            <!-- 部门经理网关 -->
            <bpmndi:BPMNShape id="shape_deptGateway" bpmnElement="deptGateway" isMarkerVisible="true">
                <dc:Bounds x="445" y="223" width="50" height="50"/>
            </bpmndi:BPMNShape>

            <!-- 总监审批 -->
            <bpmndi:BPMNShape id="shape_directorApproval" bpmnElement="directorApproval">
                <dc:Bounds x="560" y="208" width="100" height="80"/>
            </bpmndi:BPMNShape>

            <!-- 总监网关 -->
            <bpmndi:BPMNShape id="shape_finalGateway" bpmnElement="finalGateway" isMarkerVisible="true">
                <dc:Bounds x="725" y="223" width="50" height="50"/>
            </bpmndi:BPMNShape>

            <!-- 审批通过 -->
            <bpmndi:BPMNShape id="shape_approveEnd" bpmnElement="approveEnd">
                <dc:Bounds x="840" y="230" width="36" height="36"/>
            </bpmndi:BPMNShape>

            <!-- 审批驳回 -->
            <bpmndi:BPMNShape id="shape_rejectEnd" bpmnElement="rejectEnd">
                <dc:Bounds x="590" y="370" width="36" height="36"/>
            </bpmndi:BPMNShape>

            <!-- flow1: 开始 → 部门经理 -->
            <bpmndi:BPMNEdge id="edge_flow1" bpmnElement="flow1">
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="216" y="248"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="280" y="248"/>
            </bpmndi:BPMNEdge>

            <!-- flow2: 部门经理 → 网关 -->
            <bpmndi:BPMNEdge id="edge_flow2" bpmnElement="flow2">
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="380" y="248"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="445" y="248"/>
            </bpmndi:BPMNEdge>

            <!-- flow3: 网关 → 总监 (通过) -->
            <bpmndi:BPMNEdge id="edge_flow3" bpmnElement="flow3">
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="495" y="248"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="560" y="248"/>
            </bpmndi:BPMNEdge>

            <!-- flow4: 网关 → 驳回 (驳回) -->
            <bpmndi:BPMNEdge id="edge_flow4" bpmnElement="flow4">
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="470" y="273"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="470" y="388"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="590" y="388"/>
            </bpmndi:BPMNEdge>

            <!-- flow5: 总监 → 最终网关 -->
            <bpmndi:BPMNEdge id="edge_flow5" bpmnElement="flow5">
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="660" y="248"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="725" y="248"/>
            </bpmndi:BPMNEdge>

            <!-- flow6: 最终网关 → 通过 (通过) -->
            <bpmndi:BPMNEdge id="edge_flow6" bpmnElement="flow6">
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="775" y="248"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="840" y="248"/>
            </bpmndi:BPMNEdge>

            <!-- flow7: 最终网关 → 驳回 (驳回) -->
            <bpmndi:BPMNEdge id="edge_flow7" bpmnElement="flow7">
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="750" y="273"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="750" y="388"/>
                <di:waypoint xmlns:di="http://www.omg.org/spec/DD/20100524/DI" x="626" y="388"/>
            </bpmndi:BPMNEdge>

        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</definitions>
