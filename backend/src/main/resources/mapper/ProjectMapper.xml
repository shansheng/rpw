<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.company.rpw.mapper.ProjectMapper">

    <!-- 根据公司ID查询项目列表 -->
    <select id="selectByCompanyId" resultType="com.company.rpw.entity.Project">
        SELECT * FROM project
        WHERE company_id = #{companyId}
        AND deleted = 0
        ORDER BY id ASC
    </select>

    <!-- 根据状态查询项目列表 -->
    <select id="selectByStatus" resultType="com.company.rpw.entity.Project">
        SELECT * FROM project
        WHERE status = #{status}
        AND deleted = 0
        ORDER BY id ASC
    </select>

</mapper>
